<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Petoi</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .status-card {
            background: linear-gradient(135deg, #1a3a5c 0%, #0d1b2a 100%);
            border-radius: 15px;
            padding: 30px;
            margin: 30px auto;
            max-width: 800px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.3);
        }
        
        .status-indicator {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 25px;
        }
        
        .status-dot {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #ff4444;
            animation: pulse 2s infinite;
        }
        
        .status-dot.connected {
            background: #44ff44;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.7; transform: scale(1.1); }
        }
        
        .status-text {
            color: white;
            font-size: 1.4em;
            font-weight: bold;
        }
        
        .controls-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-top: 25px;
        }
        
        .control-btn {
            background: rgba(255,255,255,0.1);
            border: 2px solid rgba(255,255,255,0.3);
            color: white;
            padding: 15px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 1em;
        }
        
        .control-btn:hover {
            background: rgba(255,255,255,0.2);
            transform: translateY(-2px);
        }
        
        .control-btn:active {
            transform: translateY(0);
        }
        
        .action-log {
            background: rgba(0,0,0,0.3);
            border-radius: 10px;
            padding: 20px;
            margin-top: 25px;
            max-height: 200px;
            overflow-y: auto;
            font-family: monospace;
            font-size: 0.9em;
            color: #88ff88;
        }
        
        .log-entry {
            margin: 5px 0;
            padding: 5px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        
        .connection-form {
            display: flex;
            gap: 10px;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }
        
        .connection-form input {
            padding: 10px 15px;
            border: none;
            border-radius: 5px;
            font-size: 1em;
        }
        
        .connection-form button {
            padding: 10px 25px;
            background: #4a90d9;
            border: none;
            border-radius: 5px;
            color: white;
            cursor: pointer;
            font-size: 1em;
        }
        
        .section-title {
            color: white;
            text-align: center;
            margin: 20px 0 10px;
            font-size: 1.1em;
            opacity: 0.8;
        }
    </style>
</head>
<body>
    <nav>
        <a href="/chi-siamo">Chi Siamo</a>
        <a href="/progetto">Progetto</a>
        <a href="/storia">Storia</a>
        <a href="/dashboard" style="background: #4a90d9;">Dashboard Petoi</a>
    </nav>
    
    <main>
        <h1>Dashboard Petoi</h1>
        <p class="subtitle">Controlla il robot Petoi</p>
        
        <div class="status-card">
            <div class="status-indicator">
                <div class="status-dot" id="statusDot"></div>
                <span class="status-text" id="statusText">Verificando connessione...</span>
            </div>
            
            <div class="connection-form">
                <input type="text" id="portInput" placeholder="Porta (es. /dev/ttyUSB0)" value="/dev/ttyUSB0">
                <input type="number" id="baudInput" placeholder="Baud Rate" value="115200">
                <button onclick="connectPetoi()">Connetti</button>
                <button onclick="disconnectPetoi()" style="background: #d94a4a;">Disconnetti</button>
            </div>
            
            <p class="section-title">Movimenti Base</p>
            <div class="controls-grid">
                <button class="control-btn" onclick="executeAction('cammina')">Cammina</button>
                <button class="control-btn" onclick="executeAction('cammina-indietro')">Indietro</button>
                <button class="control-btn" onclick="executeAction('fermati')">Ferma</button>
                <button class="control-btn" onclick="executeAction('siediti')">Siediti</button>
                <button class="control-btn" onclick="executeAction('alzati')">Alzati</button>
            </div>
            
            <p class="section-title">Movimenti Testa</p>
            <div class="controls-grid">
                <button class="control-btn" onclick="executeAction('guarda-destra')">Guarda Destra</button>
                <button class="control-btn" onclick="executeAction('guarda-sinistra')">Guarda Sinistra</button>
                <button class="control-btn" onclick="executeAction('guarda-alto')">Guarda Alto</button>
                <button class="control-btn" onclick="executeAction('guarda-basso')">Guarda Basso</button>
            </div>
            
            <p class="section-title">Azioni Speciali</p>
            <div class="controls-grid">
                <button class="control-btn" onclick="executeAction('saluta')">Saluta</button>
                <button class="control-btn" onclick="executeAction('balza')">Balza</button>
                <button class="control-btn" onclick="executeAction('rotola')">Rotola</button>
                <button class="control-btn" onclick="executeAction('stretch')">Stretch</button>
                <button class="control-btn" onclick="executeAction('rest')">Riposo</button>
            </div>
            
            <p class="section-title">Reazioni a Immagini</p>
            <div class="controls-grid">
                <button class="control-btn" onclick="reactToImage('nave')">Nave</button>
                <button class="control-btn" onclick="reactToImage('mare')">Mare</button>
                <button class="control-btn" onclick="reactToImage('colombo')">Colombo</button>
                <button class="control-btn" onclick="reactToImage('america')">America</button>
            </div>
            
            <p class="section-title">Sincronizza con Sezioni Sito</p>
            <div class="controls-grid">
                <button class="control-btn" onclick="syncContent('chi-siamo')">Chi Siamo</button>
                <button class="control-btn" onclick="syncContent('progetto')">Progetto</button>
                <button class="control-btn" onclick="syncContent('storia')">Storia</button>
            </div>
            
            <p class="section-title">Visione Petoi - Avanza Galleria</p>
            <div class="controls-grid">
                <button class="control-btn" onclick="petoiSees('nave')" style="background: rgba(74, 144, 217, 0.3);">Vede Nave</button>
                <button class="control-btn" onclick="petoiSees('mare')" style="background: rgba(74, 144, 217, 0.3);">Vede Mare</button>
                <button class="control-btn" onclick="petoiSees('colombo')" style="background: rgba(74, 144, 217, 0.3);">Vede Colombo</button>
                <button class="control-btn" onclick="petoiSees('america')" style="background: rgba(74, 144, 217, 0.3);">Vede America</button>
                <button class="control-btn" onclick="petoiSees('oceano')" style="background: rgba(74, 144, 217, 0.3);">Vede Oceano</button>
            </div>
            
            <p class="section-title">Test Automatico</p>
            <div class="controls-grid">
                <button class="control-btn" onclick="startVisionSim()">Avvia Simulazione Visione</button>
                <button class="control-btn" onclick="stopVisionSim()" style="background: rgba(217, 74, 74, 0.3);">Ferma Simulazione</button>
            </div>
            
            <div class="action-log" id="actionLog">
                <div class="log-entry">Dashboard pronta</div>
            </div>
        </div>
    </main>
    
    <footer>
        <p>Colombo App 2026</p>
    </footer>
    
    <script src="/js/dashboard.js"></script>
</body>
</html>

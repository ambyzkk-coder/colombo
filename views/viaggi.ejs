<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titolo %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <a href="/">Home</a>
        <a href="/viaggi">Viaggi</a>
        <a href="/storia">Storia</a>
    </nav>
    <main>
        <h1><%= titolo %></h1>
        <div class="content">
            <% viaggi.forEach(function(viaggio) { %>
                <div class="card">
                    <h3>Anno <%= viaggio.anno %></h3>
                    <p><strong>Destinazione:</strong> <%= viaggio.destinazione %></p>
                    <p><strong>Navi:</strong> <%= viaggio.navi %></p>
                </div>
            <% }); %>
        </div>
    </main>
    <footer>
        <p>Colombo App 2026</p>
    </footer>
</body>
</html>
